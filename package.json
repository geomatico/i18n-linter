{
  "name": "@geomatico/i18n-linter",
  "version": "0.0.1",
  "description": "i18n linter for react-i18next projects, extending i18next-cli with static-key enforcement and empty-value detection",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test i18n-linter.test.mjs",
    "prepare": "husky"
  },
  "bin": {
    "i18n-linter": "i18n-linter.mjs"
  },
  "exports": {
    ".": "./i18n-linter.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geomatico/i18n-linter.git"
  },
  "author": "Geomatico <info@geomatico.es>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/geomatico/i18n-linter/issues"
  },
  "homepage": "https://github.com/geomatico/i18n-linter#readme",
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "dependencies": {
    "i18next-cli": "^1.42.10"
  }
}
